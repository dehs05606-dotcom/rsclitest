# AIA Agent environment file. Copy to .env and fill values.
# NEVER commit .env. If an API key was pasted into chat or git, revoke/rotate it.

# Provider: ollama | openai | openrouter | anthropic | gemini | opencode | nvidia
AIA_PROVIDER=ollama
AIA_MODEL=qwen2.5-coder:7b

# Effort: fast | balanced | deep | max
AIA_EFFORT=balanced
AIA_AUTO_APPLY=false
AIA_MAX_OUTPUT_TOKENS=200000
AIA_REQUEST_TIMEOUT_SECS=4000

# Ollama local
AIA_OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
OPENAI_API_KEY=
AIA_OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter
OPENROUTER_API_KEY=
AIA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenCode Zen / opencode.ai endpoint.
# You may set either the base URL or the full chat completions URL;
# AIA normalizes both forms.
OPENCODE_API_KEY=
AIA_OPENCODE_BASE_URL=https://opencode.ai/zen/v1/chat/completions
# Suggested models:
# AIA_MODEL=deepseek-v4-flash-free   # 200K context, fast
# AIA_MODEL=mimo-v2.5-free           # 1M context
# AIA_MODEL=big-pickle               # 200K context

# NVIDIA NIM / integrate API
NVIDIA_API_KEY=
AIA_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Suggested models:
# AIA_MODEL=z-ai/glm-5.2                    # 1M context
# AIA_MODEL=z-ai/glm-5.1                    # 1M context
# AIA_MODEL=deepseek-ai/deepseek-v4-pro     # 1M context
# AIA_MODEL=stepfun-ai/step-3.7-flash       # 200K context, fast

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=
